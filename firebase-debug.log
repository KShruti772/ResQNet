[debug] [2026-04-16T09:45:20.168Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/resqnet-ba073/rulesets {"name":"projects/resqnet-ba073/rulesets/dbc0309b-2198-4c0f-9122-11df03ea7776","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function hasCurrentUserProfile() {\n      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));\n    }\n\n    function currentUserOrgId() {\n      return hasCurrentUserProfile()\n        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId\n        : null;\n    }\n\n    function currentUserRole() {\n      return hasCurrentUserProfile()\n        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role\n        : null;\n    }\n\n    function isCurrentUser(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function isOrgStaffOrAdmin() {\n      return currentUserRole() == \"staff\" || currentUserRole() == \"admin\";\n    }\n\n    match /users/{userId} {\n      allow read: if isCurrentUser(userId)\n        || (\n          hasCurrentUserProfile()\n          && isOrgStaffOrAdmin()\n          && resource.data.organizationId != null\n          && resource.data.organizationId == currentUserOrgId()\n        );\n\n      allow create: if isCurrentUser(userId)\n        && request.resource.data.uid == request.auth.uid;\n\n      allow update: if isCurrentUser(userId)\n        && request.resource.data.role == resource.data.role;\n      allow delete: if false;\n    }\n\n    match /organizations/{organizationId} {\n      allow read: if isSignedIn();\n\n      allow create: if hasCurrentUserProfile()\n        && organizationId == request.resource.data.organizationId\n        && request.resource.data.createdBy == request.auth.uid;\n\n      allow update: if hasCurrentUserProfile()\n        && (\n          resource.data.createdBy == request.auth.uid\n          || isOrgStaffOrAdmin()\n        );\n\n      allow delete: if false;\n    }\n\n    match /emergencies/{emergencyId} {\n      allow create: if hasCurrentUserProfile()\n        && request.resource.data.keys().hasAll([\n          \"userId\",\n          \"organizationId\",\n          \"userName\",\n          \"location\",\n          \"status\",\n          \"createdAt\"\n        ])\n        && request.resource.data.userId == request.auth.uid\n        && request.resource.data.organizationId != null\n        && request.resource.data.organizationId == currentUserOrgId()\n        && request.resource.data.status == \"pending\";\n\n      allow read: if isSignedIn() &&\n        (\n          resource.data.userId == request.auth.uid ||\n          (\n            hasCurrentUserProfile()\n            && resource.data.organizationId != null\n            && resource.data.organizationId == currentUserOrgId()\n          )\n        );\n\n      allow update: if hasCurrentUserProfile()\n        && isOrgStaffOrAdmin()\n        && resource.data.organizationId != null\n        && resource.data.organizationId == currentUserOrgId()\n        && request.resource.data.organizationId == resource.data.organizationId\n        && request.resource.data.userId == resource.data.userId\n        && request.resource.data.createdAt == resource.data.createdAt;\n\n      allow delete: if false;\n    }\n\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-16T09:45:18.522927Z","metadata":{"services":["cloud.firestore"]}}
